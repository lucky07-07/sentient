# Copy this file to .env.local and fill in your keys.

# ── Required ──────────────────────────────────────────────────────────────

# Groq API key — text generation (qwen/qwen3-32b). Free at https://console.groq.com/keys
GROQ_API_KEY=

# Google AI Studio key — embeddings only. Free at https://aistudio.google.com
GEMINI_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────

# Override the generation model (default: qwen/qwen3-32b)
GROQ_MODEL=qwen/qwen3-32b

# Override the embedding model (default: gemini-embedding-001)
GEMINI_EMBED_MODEL=gemini-embedding-001

# Reddit OAuth app (https://www.reddit.com/prefs/apps). Enables the Reddit
# source (r/LocalLLaMA etc). Skipped and logged as a failure when absent.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# GitHub token (https://github.com/settings/tokens). Optional — raises GitHub
# API rate limits. GitHub Trending is scraped from HTML and needs no token.
GITHUB_TOKEN=
